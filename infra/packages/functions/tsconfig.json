 // tsconfig.json for the functions package
 
 {
   "compilerOptions": {
     "target": "ES2022",
     "module": "Node16",
     "moduleResolution": "Node16",
     "lib": ["ES2022"],
     "types": ["node"],
     "esModuleInterop": true,
     "strict": true,
     "skipLibCheck": true,
     "allowImportingTsExtensions": true,
     "noEmit": true
   },
   "include": ["src/**/*"]
 }